{
  "schema_name": "published_article_schema",
  "description": "Defines the structured output of a Drishvara article before HTML rendering.",
  "type": "object",
  "properties": {
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "meta_label": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "hi"
      ]
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "paragraph",
              "heading",
              "blockquote"
            ]
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "content"
        ]
      }
    },
    "closing_line": {
      "type": "string"
    },
    "image_path": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "category",
    "title",
    "subtitle",
    "meta_label",
    "slug",
    "language",
    "sections"
  ]
}
