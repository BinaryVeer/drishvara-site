{
  "$schema_name": "topic-candidate",
  "description": "Schema for daily candidate topics generated by the Topic Scout Agent.",
  "type": "object",
  "required": [
    "category",
    "date",
    "candidates"
  ],
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "spirituality",
        "sports",
        "world_affairs",
        "media_society",
        "public_programmes"
      ]
    },
    "date": {
      "type": "string",
      "description": "Date in YYYY-MM-DD format"
    },
    "candidates": {
      "type": "array",
      "minItems": 8,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "title",
          "summary",
          "angle_hint",
          "source_hints"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "angle_hint": {
            "type": "string"
          },
          "source_hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
