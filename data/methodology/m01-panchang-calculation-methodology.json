        "sunrise_basis_review",
        "ayanamsha_review",
        "licensing_review_if_external_backend_used"
      ],
      "non_marketing_rule": "The label must not be used unless the calculation basis and astronomical assumptions are explicitly declared."
    },
    {
      "key": "siddhanta_jyotisha",
      "display_names": ["Siddhanta Jyotisha", "Siddhantic Mathematical Astronomy"],
      "role_in_m01": "classical_mathematical_astronomy_foundation",
      "description": "Classical mathematical astronomy foundation relevant to Panchang elements, solar/lunar motion, time reckoning, and source-aware calculation discipline.",
      "runtime_enabled": false,
      "future_use_requires": [
        "source_review",
        "sanskrit_review",
        "calculation_review",
        "commentary_review_where_applicable"
      ],
      "separation_rule": "Mathematical astronomy must remain separate from devotional observance rules and subscriber prediction/guidance layers."
    },
    {
      "key": "surya_siddhanta",
      "display_names": ["Sūrya Siddhānta", "Surya Siddhanta"],
      "role_in_m01": "named_classical_reference_not_backend",
      "description": "Classical Sanskrit astronomical reference to be used as a source-tradition anchor and possible future comparison basis after review.",
      "runtime_enabled": false,
      "direct_algorithm_use_enabled": false,
      "future_use_requires": [
        "source_review",
        "sanskrit_review",
        "calculation_review",
        "translation_review",
        "commentary_review",
