  "panchang_elements": [
    {
      "key": "tithi",
      "basis": "angular_separation_between_moon_and_sun",
      "conceptual_formula": "floor(((moon_longitude - sun_longitude) mod 360) / 12) + 1",
      "total_units": 30,
      "requires_interval": true,
      "requires_sunrise_evaluation": true,
      "runtime_implemented": false
    },
    {
      "key": "vara",
      "basis": "weekday_with_panchang_day_boundary_to_be_declared",
      "conceptual_formula": "civil_weekday plus sunrise-boundary association",
      "requires_interval": false,
      "requires_sunrise_evaluation": true,
      "runtime_implemented": false
    },
    {
      "key": "nakshatra",
      "basis": "sidereal_moon_longitude",
      "conceptual_formula": "floor((sidereal_moon_longitude mod 360) / 13deg20min) + 1",
      "total_units": 27,
      "requires_interval": true,
      "requires_ayanamsha": true,
      "requires_sunrise_evaluation": true,
      "runtime_implemented": false
    },
    {
      "key": "yoga",
      "basis": "sum_of_sidereal_sun_and_moon_longitudes",
      "conceptual_formula": "floor(((sidereal_sun_longitude + sidereal_moon_longitude) mod 360) / 13deg20min) + 1",
      "total_units": 27,
      "requires_interval": true,
      "requires_ayanamsha": true,
      "requires_sunrise_evaluation": true,
      "runtime_implemented": false
    },
    {
      "key": "karana",
      "basis": "half_tithi_segment_plus_traditional_sequence_rule",
      "conceptual_formula": "floor(((moon_longitude - sun_longitude) mod 360) / 6) + 1, then apply reviewed karana naming sequence",
      "requires_interval": true,
      "requires_sequence_rule": true,
      "requires_sunrise_evaluation": true,
      "runtime_implemented": false
    }
  ],
  "calculation_traditions": [
    {
      "key": "drik_ganitham_thirukanitha",
      "display_names": ["Drik Ganitham", "Drig Ganita", "Thirukanitha", "Thiru Ganita"],
      "role_in_m01": "methodological_anchor_only",
      "description": "Observation/computation-oriented Panchang calculation approach using declared astronomical positions rather than unexamined fixed tables.",
      "runtime_enabled": false,
      "future_use_requires": [
        "source_review",
        "calculation_review",
