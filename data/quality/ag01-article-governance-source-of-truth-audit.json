  "file_deletion_enabled": false,
  "file_move_enabled": false,
  "audit_policy": {
    "provisional_long_form_minimum_words": 1200,
    "required_verified_reference_count": 2,
    "required_image_credit": true,
    "valid_image_statuses_for_publication": [
      "final_local_image",
      "valid_category_fallback",
      "external_image_unverified",
      "valid_local_image"
    ],
    "non_publication_image_statuses": [
      "missing_image",
      "broken_local_image",
      "logo_like_image",
      "favicon_or_brand_mark_as_hero",
      "blank_or_empty_src"
    ]
  },
  "input_files": {
    "article_glob": "articles/**/*.html",
    "router_page": "article.html",
