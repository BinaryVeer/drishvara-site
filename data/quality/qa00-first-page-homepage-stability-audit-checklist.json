  "allowed_audit_statuses": [
    "not_checked",
    "pass",
    "warning",
    "fail",
    "blocked",
    "not_applicable"
  ],
  "homepage_files_in_scope": [
    "index.html"
  ],
  "static_scan_allowed": true,
  "static_scan_mutation_allowed": false,
  "audit_items": [
    {
      "item_key": "homepage_file_present",
      "area": "static_scan",
      "check": "index.html exists at repository root.",
      "status": "not_checked"
    },
    {
      "item_key": "title_tag_present",
      "area": "seo_metadata",
      "check": "Homepage has a title tag.",
      "status": "not_checked"
    },
    {
      "item_key": "meta_description_present",
      "area": "seo_metadata",
      "check": "Homepage has meta description.",
      "status": "not_checked"
    },
    {
      "item_key": "viewport_meta_present",
      "area": "seo_metadata",
      "check": "Homepage has viewport meta tag.",
      "status": "not_checked"
    },
    {
      "item_key": "og_title_present",
      "area": "seo_metadata",
      "check": "Homepage has Open Graph title if intended.",
      "status": "not_checked"
    },
    {
      "item_key": "og_image_present",
      "area": "seo_metadata",
      "check": "Homepage has Open Graph image if intended.",
      "status": "not_checked"
    },
    {
      "item_key": "local_stylesheets_resolve",
      "area": "asset_loading",
      "check": "Local stylesheet references resolve.",
      "status": "not_checked"
    },
    {
      "item_key": "local_scripts_resolve",
      "area": "asset_loading",
      "check": "Local script references resolve.",
      "status": "not_checked"
    },
    {
      "item_key": "local_images_resolve",
      "area": "asset_loading",
      "check": "Local image references resolve.",
      "status": "not_checked"
    },
    {
      "item_key": "language_english_click_sticky",
      "area": "language_toggle",
      "check": "Clicking English keeps English, even repeatedly.",
      "status": "not_checked"
    },
    {
      "item_key": "language_hindi_click_sticky",
      "area": "language_toggle",
      "check": "Clicking Hindi keeps Hindi, even repeatedly.",
      "status": "not_checked"
    },
    {
      "item_key": "homepage_click_does_not_toggle_language",
      "area": "language_toggle",
      "check": "Normal homepage clicks do not change language.",
      "status": "not_checked"
    },
    {
      "item_key": "hindi_to_english_no_transliteration_fallback",
      "area": "language_toggle",
      "check": "Returning from Hindi to English does not show drstih vistirna style fallback.",
      "status": "not_checked"
    },
    {
      "item_key": "hero_logo_position",
      "area": "hero_visual",
      "check": "Logo position is visually balanced above/within orbit composition.",
      "status": "not_checked"
    },
    {
      "item_key": "hero_orbit_alignment",
      "area": "hero_visual",
      "check": "Orbit alignment is stable and not overlapping key text.",
      "status": "not_checked"
    },
    {
      "item_key": "hero_text_readability",
      "area": "hero_visual",
      "check": "Hero title, tagline, and meaning line are readable.",
      "status": "not_checked"
    },
    {
      "item_key": "desktop_layout_check",
      "area": "responsive",
      "check": "Homepage works on desktop width.",
      "status": "not_checked"
    },
    {
      "item_key": "tablet_layout_check",
      "area": "responsive",
      "check": "Homepage works on tablet width.",
      "status": "not_checked"
    },
    {
      "item_key": "mobile_layout_check",
      "area": "responsive",
      "check": "Homepage works on mobile width.",
      "status": "not_checked"
    },
    {
      "item_key": "small_mobile_layout_check",
      "area": "responsive",
      "check": "Homepage works on small mobile width.",
      "status": "not_checked"
    },
    {
      "item_key": "primary_navigation_links",
      "area": "links_navigation",
      "check": "Primary navigation links behave correctly.",
      "status": "not_checked"
    },
    {
      "item_key": "cta_links",
      "area": "links_navigation",
      "check": "CTA links point to intended sections/pages.",
      "status": "not_checked"
    },
    {
      "item_key": "browser_console_clean",
      "area": "console_runtime",
      "check": "Browser console has no critical JavaScript errors.",
      "status": "not_checked"
    },
    {
      "item_key": "live_homepage_loads",
      "area": "live_deployment",
      "check": "Live homepage loads after GitHub/Vercel deployment.",
      "status": "not_checked"
    },
    {
      "item_key": "live_language_toggle_works",
      "area": "live_deployment",
      "check": "Language toggle works on live page after deployment.",
      "status": "not_checked"
    },
    {
      "item_key": "live_assets_load",
      "area": "live_deployment",
      "check": "Live assets load without missing critical files.",
      "status": "not_checked"
    }
  ],
  "language_toggle_expected_behavior": [
    "english_click_keeps_english",
    "repeated_english_click_keeps_english",
    "hindi_click_keeps_hindi",
    "repeated_hindi_click_keeps_hindi",
