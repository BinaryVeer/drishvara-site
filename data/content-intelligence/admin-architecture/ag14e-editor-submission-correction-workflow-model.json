        "title",
        "category",
        "body",
        "editor_identifier"
      ],
      "admin_review_required": true,
      "execution_available_in_ag14e": false
    },
    {
      "action": "save_draft",
      "allowed_from_statuses": [
        "editor_draft",
        "editor_revision"
      ],
      "resulting_status": "same_status",
      "public_visibility_after_action": false,
      "required_fields": [
        "draft_content",
        "editor_identifier"
      ],
      "admin_review_required": false,
      "execution_available_in_ag14e": false
    },
    {
      "action": "preview",
      "allowed_from_statuses": [
        "editor_draft",
        "editor_revision",
        "returned_for_correction"
      ],
      "resulting_status": "same_status",
